# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Google OAuth (for user authentication)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Encryption key for user tokens (auto-generated if not set)
# ENCRYPTION_KEY=

# JWT secret for sessions (auto-generated if not set)
# JWT_SECRET=

# GitHub — coral source add github  (now stored per-user in DB)
GITHUB_TOKEN=ghp_...

# Linear — coral source add linear  (now stored per-user in DB)
LINEAR_API_KEY=lin_api_...

# Slack — coral source add slack  (note: SLACK_TOKEN, not SLACK_BOT_TOKEN)
SLACK_TOKEN=xoxb-...

# Sentry — coral source add sentry  (note: SENTRY_TOKEN, not SENTRY_AUTH_TOKEN)
SENTRY_TOKEN=...
SENTRY_ORG=your-org-slug

# App
FRONTEND_URL=http://localhost:3000
